      "name": "wasteadminregister",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response JSON",
              "let jsonData;",
              "pm.test(\"Response is valid JSON\", function () {",
              "    jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an(\"object\");",
              "});",
              "",
              "// Basic shape checks",
              "pm.test(\"Response has userdetails array with at least one user\", function () {",
              "    pm.expect(jsonData).to.have.property(\"userdetails\");",
              "    pm.expect(jsonData.userdetails).to.be.an(\"array\");",
              "    pm.expect(jsonData.userdetails.length).to.be.above(0);",
              "});",
              "",
              "// Assert status code is 200",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Assert response time < 2s",
              "pm.test(\"Response time is under 2000 ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Compare email in response to environment variable email2",
              "pm.test(\"Response email matches environment variable email2\", function () {",
              "    const envEmail = pm.environment.get(\"email289\");",
              "    pm.expect(envEmail, \"email2 should be set in the environment\").to.exist;",
              "    const respEmail = jsonData.userdetails[0] && pm.response.json().userdetails[0].email;",
              "    pm.expect(respEmail, \"email should exist in response\").to.exist;",
              "    pm.expect(respEmail).to.equal(envEmail);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"shalom\", (function makeEmail() {",
              "    const ts = Date.now();",
              "    const rnd = Math.random().toString(36).slice(2, 8);",
              "    const domain = \"example.com\";",
              "    return \"user_\" + ts + \"_\" + rnd + \"@\" + domain;",
              "})());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
